{
  "info": {
    "name": "PC4 Seguridad Ciudadana - API Distribuida",
    "description": "Colección de pruebas para la API PC4: health, nodos, modelo, predicción, recomendaciones, historial y métricas.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "01 Health",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "02 Nodes",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/nodes"
      }
    },
    {
      "name": "03 Model Info",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/model/info"
      }
    },
    {
      "name": "04 Predict",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"district\": 11,\n  \"community_area\": 23,\n  \"day_of_week\": 2,\n  \"hour\": 18,\n  \"week_start\": \"2026-06-01\"\n}"
        },
        "url": "{{base_url}}/predict"
      }
    },
    {
      "name": "05 Recommendations Top",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"top_n\": 3,\n  \"candidates\": [\n    {\"district\":11,\"community_area\":23,\"day_of_week\":2,\"hour\":18,\"week_start\":\"2026-06-01\"},\n    {\"district\":7,\"community_area\":68,\"day_of_week\":5,\"hour\":21,\"week_start\":\"2026-06-01\"},\n    {\"district\":12,\"community_area\":30,\"day_of_week\":6,\"hour\":22,\"week_start\":\"2026-06-01\"},\n    {\"district\":4,\"community_area\":40,\"day_of_week\":1,\"hour\":10,\"week_start\":\"2026-06-01\"},\n    {\"district\":18,\"community_area\":8,\"day_of_week\":4,\"hour\":23,\"week_start\":\"2026-06-01\"}\n  ]\n}"
        },
        "url": "{{base_url}}/recommendations/top"
      }
    },
    {
      "name": "06 Prediction History",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/predictions/history?limit=10"
      }
    },
    {
      "name": "07 Metrics",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/metrics"
      }
    }
  ]
}
